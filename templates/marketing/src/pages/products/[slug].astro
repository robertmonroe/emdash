---
import { getEmDashEntry } from "emdash";
import { PortableText } from "emdash/ui";
import Base from "../../layouts/Base.astro";
import ProductDetails from "../../components/emcommerce/ProductDetails.astro";
import FormatSelector from "../../components/emcommerce/FormatSelector.tsx";
import PreviewReader from "../../components/emcommerce/PreviewReader.tsx";

const { slug } = Astro.params;
const { entry: product } = await getEmDashEntry("products", slug!);

if (!product) {
	return Astro.redirect("/404");
}

const {
	title,
	author_name,
	author_bio,
	author_image,
	featured_image,
	short_description,
	press_quotes,
	variants,
	preview_text,
	preview_audio_url,
	narrator,
	audio_runtime,
} = product.data;

// Parse JSON fields (may be JSON string or native)
function parseJson<T>(val: unknown): T[] {
	if (typeof val === "string") { try { return JSON.parse(val); } catch { return []; } }
	if (Array.isArray(val)) return val;
	return [];
}

const parsedQuotes = parseJson<{ quote: string; source: string }>(press_quotes);
const parsedVariants = parseJson<any>(variants);

// Render preview text to HTML string for the React island
let previewHtml = "";
// We pass the raw portable text to be rendered client-side or as HTML

// Image fields in EmDash are objects with .src — handle both formats
const coverSrc = typeof featured_image === "object" && featured_image?.src
	? featured_image.src
	: typeof featured_image === "string" ? featured_image : null;
const authorImgSrc = typeof author_image === "object" && author_image?.src
	? author_image.src
	: typeof author_image === "string" ? author_image : null;

const pageTitle = author_name ? `${title} by ${author_name}` : title;
const pageDescription = short_description || `${title} — available now.`;
---

<Base title={pageTitle} description={pageDescription} image={featured_image}>
	<article class="product-page">
		<section class="product-hero container">
			<div class="hero-cover">
				{
					coverSrc ? (
						<img
							src={coverSrc}
							alt={title}
							class="cover-image"
						/>
					) : (
						<div class="cover-placeholder">
							<span>{title}</span>
						</div>
					)
				}
			</div>

			<div class="hero-info">
				<h1 class="product-title">{title}</h1>

				{author_name && (
					<p class="product-author">by {author_name}</p>
				)}

				{parsedQuotes.length > 0 && (
					<blockquote class="press-quote">
						<p>{parsedQuotes[0].quote}</p>
						<cite>&mdash; {parsedQuotes[0].source}</cite>
					</blockquote>
				)}

				{parsedVariants.length > 0 && (
					<FormatSelector
						client:visible
						variants={parsedVariants}
						productId={product.id}
						productSlug={product.slug}
						productTitle={title}
					/>
				)}

				<ProductDetails product={product} />
			</div>
		</section>

		{(preview_text || preview_audio_url) && (
			<PreviewReader
				client:visible
				previewHtml=""
				previewAudioUrl={preview_audio_url}
				narrator={narrator}
				audioRuntime={audio_runtime}
				variants={parsedVariants}
				productId={product.id}
				productSlug={product.slug}
				productTitle={title}
			/>
		)}

		{(author_name && author_bio) && (
			<section class="author-section container">
				<div class="author-card">
					{authorImgSrc && (
						<img
							src={authorImgSrc}
							alt={author_name}
							class="author-image"
						/>
					)}
					<div class="author-text">
						<h2 class="author-heading">About {author_name}</h2>
						<p class="author-bio">{author_bio}</p>
					</div>
				</div>
			</section>
		)}
	</article>
</Base>

<style>
	.product-page {
		padding-bottom: var(--spacing-5xl);
	}

	/* Hero — two-column layout */
	.product-hero {
		display: grid;
		grid-template-columns: 2fr 3fr;
		gap: var(--spacing-3xl);
		align-items: start;
		padding-top: var(--spacing-4xl);
		padding-bottom: var(--spacing-4xl);
	}

	/* Cover image */
	.hero-cover {
		position: sticky;
		top: calc(var(--spacing-4xl) + 60px);
	}

	.cover-image {
		width: 100%;
		aspect-ratio: 2 / 3;
		object-fit: cover;
		border-radius: var(--radius);
		box-shadow: var(--shadow-xl);
	}

	.cover-placeholder {
		width: 100%;
		aspect-ratio: 2 / 3;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--spacing-xl);
		text-align: center;
		font-size: var(--font-size-2xl);
		font-weight: 700;
		color: var(--color-muted);
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		box-shadow: var(--shadow-xl);
	}

	/* Info column */
	.hero-info {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-lg);
	}

	.product-title {
		font-size: var(--font-size-4xl);
		font-weight: 800;
		line-height: 1.15;
		letter-spacing: -0.03em;
	}

	.product-author {
		font-size: var(--font-size-lg);
		color: var(--color-muted);
	}

	/* Press quote */
	.press-quote {
		border-left: 4px solid var(--color-primary);
		padding: var(--spacing-md) var(--spacing-lg);
		margin: var(--spacing-md) 0;
		background: var(--color-surface);
		border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
	}

	.press-quote p {
		font-size: var(--font-size-lg);
		font-style: italic;
		line-height: 1.6;
		color: var(--color-text);
		margin-bottom: var(--spacing-sm);
	}

	.press-quote cite {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		font-style: normal;
	}

	/* Preview reader placeholder */
	#preview-reader {
		margin-top: var(--spacing-3xl);
		margin-bottom: var(--spacing-3xl);
	}

	/* Author section */
	.author-section {
		border-top: 1px solid var(--color-border);
		padding-top: var(--spacing-3xl);
	}

	.author-card {
		display: flex;
		gap: var(--spacing-xl);
		align-items: flex-start;
		max-width: var(--max-width);
	}

	.author-image {
		width: 100px;
		height: 100px;
		border-radius: var(--radius-full);
		object-fit: cover;
		flex-shrink: 0;
	}

	.author-heading {
		font-size: var(--font-size-xl);
		font-weight: 700;
		margin-bottom: var(--spacing-sm);
	}

	.author-bio {
		font-size: var(--font-size-base);
		color: var(--color-muted);
		line-height: 1.7;
	}

	/* Responsive */
	@media (max-width: 768px) {
		.product-hero {
			grid-template-columns: 1fr;
			gap: var(--spacing-xl);
			padding-top: var(--spacing-2xl);
			padding-bottom: var(--spacing-2xl);
		}

		.hero-cover {
			position: static;
			max-width: 320px;
			margin: 0 auto;
		}

		.product-title {
			font-size: var(--font-size-3xl);
		}

		.author-card {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
	}
</style>
