---
interface Variant {
	price: number;
	[key: string]: unknown;
}

interface Props {
	product: {
		slug: string;
		data: {
			title: string;
			author_name?: string;
			featured_image?: string;
			price?: number;
			variants?: Variant[] | string;
			[key: string]: unknown;
		};
	};
}

const { product } = Astro.props;
const { title, author_name, featured_image, variants, price } = product.data;

// Parse variants (may be JSON string or array)
let parsedVariants: Variant[] = [];
if (typeof variants === "string") {
	try {
		parsedVariants = JSON.parse(variants);
	} catch {}
} else if (Array.isArray(variants)) {
	parsedVariants = variants;
}

// Calculate price display
let priceDisplay = "";
if (parsedVariants.length > 0) {
	const prices = parsedVariants.map((v) => v.price).sort((a, b) => a - b);
	const lowest = (prices[0] / 100).toFixed(2);
	const highest = (prices[prices.length - 1] / 100).toFixed(2);
	if (prices.length === 1 || lowest === highest) {
		priceDisplay = `$${lowest}`;
	} else {
		priceDisplay = `$${lowest} - $${highest}`;
	}
} else if (price) {
	priceDisplay = `From $${(price / 100).toFixed(2)}`;
}
---

<a href={`/products/${product.slug}`} class="product-card">
	<div class="product-card__image-wrap">
		{
			featured_image ? (
				<img
					src={featured_image}
					alt={title}
					class="product-card__image"
					loading="lazy"
				/>
			) : (
				<div class="product-card__placeholder">
					<span>{title}</span>
				</div>
			)
		}
	</div>
	<div class="product-card__body">
		<h3 class="product-card__title">{title}</h3>
		{author_name && <p class="product-card__author">{author_name}</p>}
		{priceDisplay && <p class="product-card__price">{priceDisplay}</p>}
	</div>
</a>

<style>
	.product-card {
		display: block;
		background: var(--color-surface);
		border: 1px solid var(--color-border);
		border-radius: var(--radius);
		overflow: hidden;
		transition:
			transform var(--transition-base),
			box-shadow var(--transition-base);
	}

	.product-card:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-lg);
	}

	.product-card__image-wrap {
		aspect-ratio: 2 / 3;
		overflow: hidden;
		background: var(--color-border);
	}

	.product-card__image {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.product-card__placeholder {
		width: 100%;
		height: 100%;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: var(--spacing-lg);
		text-align: center;
		font-size: var(--font-size-lg);
		font-weight: 600;
		color: var(--color-muted);
		background: var(--color-surface);
	}

	.product-card__body {
		padding: var(--spacing-md) var(--spacing-lg) var(--spacing-lg);
	}

	.product-card__title {
		font-size: var(--font-size-base);
		font-weight: 700;
		line-height: 1.3;
		margin-bottom: var(--spacing-xs);
	}

	.product-card__author {
		font-size: var(--font-size-sm);
		color: var(--color-muted);
		margin-bottom: var(--spacing-sm);
	}

	.product-card__price {
		font-size: var(--font-size-sm);
		font-weight: 600;
		color: var(--color-primary);
	}
</style>
