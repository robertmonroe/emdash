---
import { getEmDashCollection } from "emdash";
import Base from "../../layouts/Base.astro";
import ProductCard from "../../components/emcommerce/ProductCard.astro";

const { entries: allProducts } = await getEmDashCollection("products");

const products = (allProducts ?? []).filter(
	(p) => p.data.product_status === "active"
);
---

<Base title="Shop" description="Browse our collection of books.">
	<section class="shop-page">
		<div class="container">
			<h1 class="shop-page__title">Shop</h1>
			{
				products.length > 0 ? (
					<div class="product-grid">
						{products.map((product) => (
							<ProductCard product={product} />
						))}
					</div>
				) : (
					<div class="empty-state">
						<p>No products available yet. Check back soon!</p>
					</div>
				)
			}
		</div>
	</section>
</Base>

<style>
	.shop-page {
		padding: var(--spacing-3xl) 0 var(--spacing-5xl);
	}

	.shop-page__title {
		margin-bottom: var(--spacing-2xl);
	}

	.product-grid {
		display: grid;
		grid-template-columns: repeat(4, 1fr);
		gap: var(--spacing-xl);
	}

	@media (max-width: 1024px) {
		.product-grid {
			grid-template-columns: repeat(2, 1fr);
		}
	}

	@media (max-width: 540px) {
		.product-grid {
			grid-template-columns: 1fr;
		}
	}

	.empty-state {
		text-align: center;
		padding: var(--spacing-5xl) var(--spacing-lg);
		color: var(--color-muted);
		font-size: var(--font-size-lg);
	}
</style>
